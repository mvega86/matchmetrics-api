# ── Base de datos ────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/api_party
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# ── Seguridad JWT ────────────────────────────────────────────
JWT_SECRET=cambia-esto-en-produccion-min-32-caracteres

# ── CORS (separar por comas si hay varios orígenes) ──────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── URL base del backend (para fotos de perfil, etc.) ────────
# En local: http://localhost:8080
# En Render: https://tu-backend.onrender.com
APP_BASE_URL=http://localhost:8080

# ── Email — Resend (https://resend.com) ──────────────────────
# Dejar vacío en local → stub muestra el código en consola
# En producción: rellenar RESEND_API_KEY y poner EMAIL_STUB_ALLOWED=false
RESEND_API_KEY=
APP_FROM_EMAIL=MatchMetrics <noreply@tudominio.com>
APP_FRONTEND_URL=http://localhost:5173
# false → error en arranque si falta RESEND_API_KEY (obligatorio en producción)
EMAIL_STUB_ALLOWED=true

# ── SMS — desactivado hasta configurar proveedor ─────────────
# Si SMS_ENABLED=true, las tres variables de Twilio son obligatorias
# SMS_ENABLED=true
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+34600000000

# ── Logs — en producción no se necesitan; activar en local ───
# SHOW_SQL=true
# LOG_LEVEL_FLYWAY=DEBUG
# LOG_LEVEL_JDBC=DEBUG
# LOG_LEVEL_SQL=DEBUG
