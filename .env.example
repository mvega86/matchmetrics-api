# ── Base de datos ────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/api_party
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# ── Seguridad JWT ────────────────────────────────────────────
JWT_SECRET=cambia-esto-en-produccion-min-32-caracteres

# ── CORS (separar por comas si hay varios orígenes) ──────────
